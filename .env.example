PORT=3000
LOG_LEVEL=info

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=chirp
MYSQL_USER=root
MYSQL_PASSWORD=password

# Rate limit settings
RATE_LIMIT_IP_PER_HOUR=200
RATE_LIMIT_PROJECT_PER_DAY=100000
RATE_LIMIT_CLIENT_PER_HOUR=500

# Retention in days (events older than this are pruned after rollup)
RETENTION_DAYS=90
